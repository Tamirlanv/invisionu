# --- API (FastAPI / Railway) ---
# Базовый URL бэкенда без завершающего слэша.
# Локально: http://localhost:8000
# Docker (web): http://api:8000 — задаётся в compose при сборке образа
# Vercel: https://YOUR-SERVICE.up.railway.app  (обязательно в Project → Environment Variables для Production)
API_INTERNAL_URL=http://localhost:8000

# Опционально для клиентских скриптов; для основного флоу достаточно относительных /api/v1 на том же хосте.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- API: Resend (код подтверждения email при регистрации) ---
# Домен в «From» должен быть проверен в https://resend.com/domains (у проекта — oku.com.kz, не invision.kz).
RESEND_API_KEY=
EMAIL_FROM=noreply@oku.com.kz

# --- Dev seed: commission login bootstrap (scripts/seed.py) ---
COMMISSION_SEED_EMAIL=commission@example.com
COMMISSION_SEED_ROLE=admin
COMMISSION_SEED_PASSWORD=DevCommission123!
# Optional aliases supported too:
# COMMISSION_LOGIN=commission@example.com
# COMMISSION_PASSWORD=DevCommission123!
