# --- Database ---
POSTGRES_USER=invision
POSTGRES_PASSWORD=invision
POSTGRES_DB=invision
DATABASE_URL=postgresql+asyncpg://invision:invision@localhost:5432/invision

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-me-use-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
CORS_ORIGINS=http://localhost:3000

# --- Storage ---
UPLOAD_ROOT=./data/uploads
MAX_UPLOAD_BYTES_DEFAULT=10485760

# --- Resend (email verification) ---
# Domain must be verified in Resend; use your org domain (e.g. oku.com.kz).
RESEND_API_KEY=
EMAIL_FROM=noreply@oku.com.kz
APP_PUBLIC_URL=http://localhost:3000

# --- OpenAI (committee / AI features — no autonomous decisions) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Next.js ---
# Browser uses same-origin /api/v1 via rewrites in dev/prod web container.
NEXT_PUBLIC_API_URL=http://localhost:8000
# Server-side Next.js (Docker web service) calls API by service name:
API_INTERNAL_URL=http://127.0.0.1:8000
